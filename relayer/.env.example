# TEE Oracle Relayer Configuration

# Public HTTPS endpoint serving the TEE pull API
ORACLE_API_URL=https://oracle.kaskad.live

# Galleon testnet RPC
RPC_URL=https://rpc.galleon.kaskad.io

# KaskadPriceOracle contract address
ORACLE_ADDRESS=0x...

# Gas-payer private key (NOT the enclave signer — any funded wallet)
PRIVATE_KEY=0x...

# Poll interval in seconds (default: 10)
POLL_INTERVAL=10

# Relay interval in seconds (default: 15)
RELAY_INTERVAL=15
