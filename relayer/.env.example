# TEE Oracle Relayer Configuration

# ALB URL serving the TEE pull API
ORACLE_API_URL=http://kaskad-oracle-alb-670133639.us-east-1.elb.amazonaws.com

# Galleon testnet RPC
RPC_URL=https://rpc.galleon.kaskad.io

# KaskadPriceOracle contract address
